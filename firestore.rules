rules_version = '2';

// ── FERPA-compliant, multi-tenant Firestore rules ─────────────────────────────
//
// Auth model: Firestore user-doc (not custom claims).
//   The source of truth for a user's school and role is stored in:
//     users/{uid}  →  { status, schoolId, role, ... }
//
//   This avoids the need for a Cloud Function to mint custom claims, and
//   lets role/status changes take effect on the next request without
//   requiring a token refresh.
//
// Tenant isolation:
//   All school data lives under schools/{schoolId}.
//   A user may only access data for the school listed in their user doc,
//   and only when status == "active".
//
// Role model (stored in users/{uid}.role):
//   "admin"  – full read/write on catalog, teachers, config, schedules,
//              and the users/access subcollection for their school.
//   "staff"  – read catalog/teachers; read/write schedules and students.
//   "viewer" – read-only on catalog and schedules (e.g. counselors).
//
// FERPA boundary:
//   Student records (schools/{id}/students/**) require role admin or staff.
//   No student data is readable by viewers or unauthenticated users.
//
// Bootstrap (first admin):
//   The app logic auto-approves the first user who requests access to a school
//   as admin.  The rules allow any authenticated user to:
//     • read  schools/{schoolId}  (to populate the school picker)
//     • create/update users/{uid} (to store their own access request)
//     • create schools/{schoolId}/access/{uid} for themselves
//   Nothing else is open without an active user doc.
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────────

    // Read the caller's user doc.  Returns the data map or null.
    function userDocData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Is the caller authenticated and does their active user doc belong to
    // the given school?
    function isActive(schoolId) {
      let u = userDocData();
      return request.auth != null
          && u != null
          && u.status   == 'active'
          && u.schoolId == schoolId;
    }

    // Is the caller an admin for this school?
    function isAdmin(schoolId) {
      let u = userDocData();
      return request.auth != null
          && u != null
          && u.status   == 'active'
          && u.schoolId == schoolId
          && u.role     == 'admin';
    }

    // Is the caller admin or staff for this school?
    function isStaff(schoolId) {
      let u = userDocData();
      return request.auth != null
          && u != null
          && u.status   == 'active'
          && u.schoolId == schoolId
          && u.role     in ['admin', 'staff'];
    }

    // ── User docs ─────────────────────────────────────────────────────────────
    // Users may read and write their own doc (to store/update access requests).
    // Admins may read any user doc whose schoolId matches their own school
    // (needed so UsersPanel can resolve displayName/email from uid).
    match /users/{uid} {
      // Owner: always allowed to read/write their own doc.
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Admin of the same school may read (not write) other users' docs.
      allow read: if request.auth != null
                  && request.auth.uid != uid
                  && isAdmin(userDocData().schoolId);
    }

    // ── Schools index ─────────────────────────────────────────────────────────
    // Any authenticated user may list/read schools so the picker can populate.
    // Only admins of that school (or the app bootstrap path) may write the
    // top-level document.  The bootstrap write is allowed for any authenticated
    // user because the first admin must be able to create the school doc before
    // their user doc is approved.
    match /schools/{schoolId} {
      allow read: if request.auth != null;

      // Existing admins may update.
      allow update: if isAdmin(schoolId);

      // Any authenticated user may create a school doc (bootstrap path).
      // The app only does this when no active users exist for that school yet.
      allow create: if request.auth != null;

      // ── School config ───────────────────────────────────────────────────────
      match /config/{docId} {
        allow read:  if isActive(schoolId);
        allow write: if isAdmin(schoolId);
      }

      // ── Access subcollection ────────────────────────────────────────────────
      // Admins of the school may read the full subcollection (list pending reqs).
      // Any authenticated user may write their own access doc (request access /
      // bootstrap first-admin).
      match /access/{uid} {
        allow read:  if isAdmin(schoolId);
        allow write: if request.auth != null && request.auth.uid == uid;

        // Admin may also write other users' access docs (approve / reject / role
        // changes).  We check schoolId == schoolId to prevent cross-school abuse.
        allow write: if isAdmin(schoolId);
      }

      // ── Course catalog ───────────────────────────────────────────────────────
      match /courses/{courseId} {
        allow read:  if isActive(schoolId);
        allow write: if isAdmin(schoolId);
      }

      // ── Teacher roster ───────────────────────────────────────────────────────
      match /teachers/{teacherId} {
        allow read:  if isActive(schoolId);
        allow write: if isAdmin(schoolId);
      }

      // ── Requirement groups ───────────────────────────────────────────────────
      match /requirement-groups/{groupId} {
        allow read:  if isActive(schoolId);
        allow write: if isAdmin(schoolId);
      }

      // ── Student types ────────────────────────────────────────────────────────
      match /student-types/{typeId} {
        allow read:  if isActive(schoolId);
        allow write: if isAdmin(schoolId);
      }

      // ── Schedule versions ────────────────────────────────────────────────────
      // Admin and staff may save/load/promote/archive versions.
      // Viewers may read (e.g. counselors reviewing the active schedule).
      // NOTE: schedule docs contain class-period data only, not student names.
      match /schedules/{scheduleId} {
        allow read:  if isActive(schoolId);
        allow write: if isStaff(schoolId);
      }

      // ── Validate-schedule sessions ───────────────────────────────────────────
      // Saved "validate" sessions are named snapshots of a student's course
      // selections against a generated schedule.  They contain student name and
      // course choices but no grades, assessments, or other FERPA-sensitive data.
      // Any active user may read; admin and staff may write.
      match /validate-sessions/{sessionId} {
        allow read:  if isActive(schoolId);
        allow write: if isStaff(schoolId);
      }

      // ── Student records (FERPA) ──────────────────────────────────────────────
      // Restricted to admin and staff only.  Viewers cannot access this subtree.
      match /students/{studentId} {
        allow read, write: if isStaff(schoolId);

        match /requests/{requestId} {
          allow read, write: if isStaff(schoolId);
        }

        match /schedules/{scheduleId} {
          allow read, write: if isStaff(schoolId);
        }
      }
    }

    // ── Deny everything else ──────────────────────────────────────────────────
    // Explicit catch-all prevents any unmatched path from defaulting to allow.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
